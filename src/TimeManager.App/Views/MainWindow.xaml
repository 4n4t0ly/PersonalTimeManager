<Window x:Class="TimeManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeManager.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="470" Width="800">
    <Grid Background="DarkGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="2" Background="GhostWhite" Margin="5">
            <Label Content="Completed tasks:"/>
            <ListBox Name="CompletedTasksBox"
                     Height="349" ItemsSource="{Binding CompletedTasks}"
                     Width="200" Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Width="95"/>
                            <TextBlock Text="{Binding ActualTimeSpentText}" Width="90"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Name="CalendarButton" Content="Calendar" Height="35" Width="209" Click="CalendarButton_Click"/>
        </StackPanel>
            <StackPanel Grid.Column="1" Background="AliceBlue" Margin="5">
                <Label Name="TimerLabel" Content="00:00:00"
                       FontSize="64"
                       HorizontalAlignment="Center"/>
                <Label Name="CurrentTime" Content="%TIME%"
                       FontSize="22"
                       HorizontalAlignment="Right"/>
                <TextBlock
                        Background="White"
                         Text="{Binding CurrentTaskText}"
                         Height="206"
                         TextWrapping="Wrap" Margin="5"/>
            <Button Name="StartButton" Content="Start" Height="35" Click="StartButton_Click"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Name="DeleteButton"
                    Content="Delete Task"
                    Grid.Column="0"
                    Height="35" Click="DeleteButton_Click"/>
                <Button Name="PauseButton"
                    Content="Pause"
                    Grid.Column="1"
                    Height="35" Click="PauseButton_Click"/>
            </Grid>
            </StackPanel>

            <StackPanel Grid.Column="0" Background="GhostWhite" Margin="5">
                <Label Content="     Name     |    Category     |  P  |  D"
                       Height="27"/>
            <ListBox Name="ScheduleBox" Height="348"
                         Width="200" Margin="5"
                         ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding CurrentTask, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Width="80"/>
                            <TextBlock Text="{Binding Category}" Width="70"/>
                            <TextBlock Text="{Binding Priority}" Width="15"/>
                            <TextBlock Text="{Binding Difficulty}" Width="20"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Name="AddButton" Content="+Add" Height="35" Click="AddButton_Click"/>
            </StackPanel>

    </Grid>
</Window>
