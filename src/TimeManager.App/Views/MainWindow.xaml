<Window x:Class="TimeManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeManager.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="470" Width="800">
    <Grid Background="DarkGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Background="GhostWhite" Margin="5">
            <ListBox Name="DaysBox" Height="375"
                         Width="200" Margin="5"/>
            <Button Name="CalendarButton" Content="Calendar" Height="35" Width="209" Click="Button_Click"/>
        </StackPanel>
            <StackPanel Grid.Column="1" Background="AliceBlue" Margin="5">
                <Label Name="Timer" Content="00:00:00"
                       FontSize="64"
                       HorizontalAlignment="Center"/>
                <Label Name="CurrentTime" Content="00:00"
                       FontSize="22"
                       HorizontalAlignment="Right"/>
                <TextBox Name="DescriptionBox"
                         Height="206"
                         TextWrapping="Wrap" Margin="5"/>
            <Button Name="StartButton" Content="Start" Height="35" Click="StartButton_Click"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Name="SkipButton"
                    Content="Skip"
                    Grid.Column="0"
                    Height="35" Click="SkipButton_Click"/>
                <Button Name="ShuffleButton"
                    Content="Shuffle tasks"
                    Grid.Column="1"
                    Height="35" Click="ShuffleButton_Click"/>
            </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2" Background="GhostWhite" Margin="5">
                <Label Content="Name    Priority    Type    Difficulty"
                       Height="27"/>
                <ListBox Name="SceduleBox" Height="348"
                         Width="200" Margin="5"
                         />
                <Button Name="AddButton" Content="+Add" Height="35" Click="AddButton_Click"/>
            </StackPanel>

    </Grid>
</Window>
