<Window x:Class="TimeManager.App.Views.AddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeManager.App.Views"
        mc:Ignorable="d"
        PreviewKeyDown="Window_KeyDown"
        Title="AddTaskWindow" Height="300" Width="500">
    <Grid Background="LightGray" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0"
       Content="Name*:"
       VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
         Margin="5"
          Name="NameBox"/>
        <Label Grid.Row="0" Grid.Column="2"
       Content="Priority:"
       VerticalAlignment="Center"/>

        <TextBox Grid.Row="0" Grid.Column="3"
         Margin="5"
         Name="PriorityBox"/>
        <Label Grid.Row="1" Grid.Column="2"
            Content="Difficulty:"
            VerticalAlignment="Center"/>

        <TextBox Grid.Row="1" Grid.Column="3"
            Margin="5"
            Name="DiffBox"/>
        <Label Grid.Row="1" Grid.Column="0" Content="Category:"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
          IsEditable="True"
          Name="CategoryComboBox"
           ItemsSource="{Binding Categories}"
            DisplayMemberPath="Name"
            SelectedItem="{Binding SelectedCategory}"/>
        <Label Grid.Column="0" Grid.Row="2" Content="DeadLine:"/>
        <DatePicker Grid.Row="2" Grid.Column="1"
                    Name="DeadLinePick"/>
        <Label Grid.Column="2" Grid.Row="2"
               Content="Time to do:"/>
        <TextBox Grid.Column="3" Grid.Row="2"
                 Name="TimeToDoBox"/>
        <Label Grid.Column="0" Grid.Row="3"
               Content="Description:"/>
        <RichTextBox Grid.Column="1" Grid.Row="3"
                     Name="DescriptionBox"/>
        <StackPanel Grid.Row="4"
            Grid.ColumnSpan="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <Button Content="Add" Name="AddButton"
            Width="100"
            Margin="5" Click="AddButton_Click"/>
            <Button Content="Close" Name="CloseButton"
            Width="100"
            Margin="5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
